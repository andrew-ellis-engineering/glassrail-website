{
  "name": "glassrail-product-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "format": "prettier --check index.html package.json tsconfig.json vite.config.ts .github/workflows/pages.yml 'src/**/*.{ts,css}'",
    "format:write": "prettier --write index.html package.json tsconfig.json vite.config.ts .github/workflows/pages.yml 'src/**/*.{ts,css}'"
  },
  "dependencies": {
    "gsap": "^3.13.0"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
